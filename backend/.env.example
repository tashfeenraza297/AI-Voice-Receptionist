# ── Vapi ────────────────────────────────────────────────────────────────────
# Sign up free at https://vapi.ai — $10 credit included, no credit card needed
# All keys are found at: https://dashboard.vapi.ai/account

# Private API Key (server-side only — never expose in frontend)
VAPI_PRIVATE_KEY=your_vapi_private_key_here

# Public API Key (used by browser Vapi Web SDK)
VAPI_PUBLIC_KEY=your_vapi_public_key_here

# Phone Number ID (only needed for outbound PSTN calls — not required for web calls)
# Get from: https://dashboard.vapi.ai/phone-numbers
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here

# ── App ──────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
